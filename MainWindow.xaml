<Window x:Class="BruteForceCracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Slaptažodžių Atstatymo Programa (Brute-Force)"
        Height="460"
        Width="680"
        Background="#F4F6F9">
    <Grid Margin="20">
        <StackPanel>
            
            <GroupBox Header="1. Slaptažodžio Paruošimas" Padding="10" Margin="0,0,0,15" FontWeight="Bold">
                <Grid>
                    <Button Content="Sugeneruoti Slaptažodį" Click="BtnGenerate_Click" HorizontalAlignment="Left" Width="150" Height="30" FontWeight="Normal"/>
                    <TextBlock Text="Tekstas:" Margin="165,7,0,0" HorizontalAlignment="Left" FontWeight="Normal"/>
                    <TextBox x:Name="TxtPlain" Margin="215,0,0,0" Width="60" HorizontalAlignment="Left" IsReadOnly="True" VerticalContentAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Text="SHA256 Maiša:" Margin="290,7,0,0" HorizontalAlignment="Left" FontWeight="Normal"/>
                    <TextBox x:Name="TxtHash" Margin="380,0,0,0" IsReadOnly="True" VerticalContentAlignment="Center" FontFamily="Consolas" FontWeight="Normal"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="2. Atakos Valdymas ir Laikas" Padding="10" Margin="0,0,0,15" FontWeight="Bold">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button x:Name="BtnStart" Content="START" Click="BtnStart_Click" Background="#2ECC71" Foreground="White" Width="110" Height="35" FontWeight="Bold"/>
                        <Button x:Name="BtnStop" Content="STOP" Click="BtnStop_Click" Background="#E74C3C" Foreground="White" Width="110" Height="35" IsEnabled="False" Margin="10,0,0,0" FontWeight="Bold"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,10,0">
                        <TextBlock Text="Praėjęs laikas: " VerticalAlignment="Center" FontWeight="Normal"/>
                        <TextBlock x:Name="LblTime" Text="00:00:00.000" FontSize="20" FontWeight="Bold" FontFamily="Consolas" Foreground="#2C3E50" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <Grid Height="160">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*"/>
                    <ColumnDefinition Width="5*"/>
                </Grid.ColumnDefinitions>
                
                <GroupBox Header="Rastas Slaptažodis" Margin="0,0,5,0" FontWeight="Bold">
                    <TextBox x:Name="TxtResult" IsReadOnly="True" FontSize="26" FontWeight="Bold" Foreground="#27AE60" Background="Black" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontFamily="Consolas"/>
                </GroupBox>
                
                <GroupBox Grid.Column="1" Header="Našumo Žurnalas (Logas)" Margin="5,0,0,0" FontWeight="Bold">
                    <TextBox x:Name="TxtLog" IsReadOnly="True" Background="#1E1E1E" Foreground="#A9B7C6" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" FontWeight="Normal" Padding="5"/>
                </GroupBox>
            </Grid>
            
            <StatusBar Margin="0,15,0,0" Background="#BDC3C7">
                <StatusBarItem>
                    <TextBlock x:Name="LblStatus" Text="Sistemos būsena: Laukiama veiksmų..." Foreground="#2C3E50" FontWeight="Medium"/>
                </StatusBarItem>
            </StatusBar>
            
        </StackPanel>
    </Grid>
</Window>